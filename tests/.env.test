# Test environment configuration for local services
# This file is used when running tests against local Docker Compose services

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
ML_ENVIRONMENT=test
ML_DATABASE_TYPE=local
DATABASE_TYPE=local
DEBUG=true
LOG_LEVEL=DEBUG

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
VALIDATE_CONFIG_ON_STARTUP=false
STRICT_CONFIG_VALIDATION=false
ENABLE_HEALTH_CHECKS=false
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# TEST DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL (use test database)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=multimodal_librarian_test
POSTGRES_USER=ml_user
POSTGRES_PASSWORD=ml_password
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Neo4j (use test database)
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ml_password
NEO4J_URI=bolt://localhost:7687

# Milvus (use test collection)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=test_knowledge_chunks

# Redis (use test database)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# =============================================================================
# TEST OPTIMIZATIONS
# =============================================================================
# Shorter timeouts for faster test execution
CONNECTION_TIMEOUT=10
QUERY_TIMEOUT=5
HEALTH_CHECK_TIMEOUT=3
MAX_RETRIES=1
RETRY_DELAY=0.1

# Disable external services for testing
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# FEATURE FLAGS FOR TESTING
# =============================================================================
ENABLE_DOCUMENT_UPLOAD=true
ENABLE_KNOWLEDGE_GRAPH=true
ENABLE_VECTOR_SEARCH=true
ENABLE_AI_CHAT=false  # Disabled for tests without API keys
ENABLE_EXPORT_FUNCTIONALITY=true
ENABLE_ANALYTICS=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_FORMAT=json
ENABLE_STRUCTURED_LOGGING=true
ENABLE_QUERY_LOGGING=false  # Reduce noise in tests
ENABLE_PERFORMANCE_PROFILING=false

# =============================================================================
# SECURITY SETTINGS (TEST VALUES)
# =============================================================================
SECRET_KEY=test-secret-key-for-testing-only
ENCRYPTION_KEY=dGVzdC1lbmNyeXB0aW9uLWtleS1mb3ItdGVzdGluZy1vbmx5
REQUIRE_AUTH=false
ENABLE_REGISTRATION=true

# =============================================================================
# FILE STORAGE (TEST DIRECTORIES)
# =============================================================================
UPLOAD_DIR=/tmp/test_uploads
MEDIA_DIR=/tmp/test_media
EXPORT_DIR=/tmp/test_exports
BACKUP_DIR=/tmp/test_backups
LOG_DIR=/tmp/test_logs

# =============================================================================
# PROCESSING SETTINGS (OPTIMIZED FOR TESTS)
# =============================================================================
CHUNK_SIZE=256  # Smaller chunks for faster tests
CHUNK_OVERLAP=25
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=16

# =============================================================================
# PERFORMANCE SETTINGS (OPTIMIZED FOR TESTS)
# =============================================================================
MAX_WORKER_PROCESSES=2
MAX_WORKER_THREADS=4
WORKER_TIMEOUT=60
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=10

# =============================================================================
# TEST DATA CONFIGURATION
# =============================================================================
GENERATE_TEST_DATA=true
TEST_DATA_SIZE=small
RESET_TEST_DATA_ON_STARTUP=true
ENABLE_TEST_ENDPOINTS=true
MOCK_EXTERNAL_APIS=true