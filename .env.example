# Multimodal Librarian Environment Configuration
# Copy this file to .env and update the values for your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="Multimodal Librarian"
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY=your-api-key-here

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Generate a secure secret key for JWT tokens
SECRET_KEY=your-super-secret-key-change-in-production

# Generate a base64 encoded encryption key (32 bytes)
# python -c "import base64; import os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=your-base64-encoded-encryption-key

# Authentication settings
REQUIRE_AUTH=false
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Password policy
MIN_PASSWORD_LENGTH=8
REQUIRE_PASSWORD_COMPLEXITY=true

# Session management
SESSION_TIMEOUT_MINUTES=60
MAX_CONCURRENT_SESSIONS=5

# Rate limiting and security
RATE_LIMIT_PER_MINUTE=60
WEBSOCKET_TIMEOUT=3600  # 1 hour for large uploads
ALLOWED_ORIGINS=["*"]

# Audit and data retention
AUDIT_LOG_RETENTION_DAYS=365
ENABLE_DETAILED_AUDIT=true
DATA_RETENTION_DAYS=2555
AUTO_CLEANUP_ENABLED=false

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=multimodal_librarian
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# AWS-Native Databases (Neptune and OpenSearch)
# Note: Legacy Neo4j and Milvus have been removed. Use AWS-native services.
# Configure Neptune endpoint for knowledge graph operations
NEPTUNE_ENDPOINT=your-neptune-cluster-endpoint.region.neptune.amazonaws.com
NEPTUNE_PORT=8182

# Configure OpenSearch endpoint for vector search operations
OPENSEARCH_ENDPOINT=your-opensearch-domain-endpoint.region.es.amazonaws.com
OPENSEARCH_PORT=443
OPENSEARCH_INDEX_NAME=knowledge_chunks

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================
# Google Gemini API for AI generation and embeddings
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# FILE STORAGE SETTINGS
# =============================================================================
UPLOAD_DIR=uploads
MEDIA_DIR=media
EXPORT_DIR=exports
MAX_FILE_SIZE=10737418240  # 10GB - effectively unlimited

# =============================================================================
# PROCESSING SETTINGS
# =============================================================================
# Text chunking configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================================
# EXTERNAL KNOWLEDGE BASES
# =============================================================================
YAGO_ENDPOINT=https://yago-knowledge.org/sparql/query
CONCEPTNET_API_BASE=http://api.conceptnet.io

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Set to true for development
DEV_MODE=false

# Test database settings (for running tests)
TEST_POSTGRES_DB=multimodal_librarian_test
TEST_OPENSEARCH_INDEX=knowledge_chunks_test

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# SSL/TLS settings (for production)
SSL_CERT_PATH=/etc/ssl/certs/cert.pem
SSL_KEY_PATH=/etc/ssl/private/key.pem

# Monitoring and logging
SENTRY_DSN=your-sentry-dsn-for-error-tracking
LOG_FILE_PATH=/app/logs/app.log
AUDIT_LOG_PATH=/app/audit_logs/audit.log

# Performance settings
MAX_WORKERS=4
WORKER_TIMEOUT=300
KEEP_ALIVE=2

# Cache settings (if using Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
CACHE_TTL=3600