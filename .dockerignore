# Docker ignore file for Multimodal Librarian
# Optimizes build context and reduces image size

# Version control
.git
.gitignore
.gitattributes

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Documentation
docs/_build/
.readthedocs.yml

# Local development files
.env.local
.env.*.local
*.log
logs/
audit_logs/

# Data directories (these should be mounted as volumes)
data/
backups/
uploads/
media/
exports/
test_uploads/
test_media/
test_exports/
test_data/
cache/
notebooks/

# Docker files (except the main ones)
docker-compose.override.yml
docker-compose.*.yml
!docker-compose.local.yml
!docker-compose.yml

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# AWS and infrastructure files
*.pem
*.key
terraform.tfstate*
.terraform/
*.tfvars
!*.tfvars.example

# Large model files and caches (these will be downloaded in container)
.cache/
*.model
*.bin
models/

# Monitoring and performance files
*.prof
*.pstats

# Local configuration overrides
config/local/
local_config.py

# Backup files
*.bak
*.backup
*.old

# Archive files
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# Compiled documentation
docs/build/

# Node.js (if any frontend assets)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local database files (should be in volumes)
*.db
*.sqlite
*.sqlite3

# Kiro specs and steering (development only)
.kiro/

# Performance and profiling
*.prof
*.pstats
profile_*

# Local scripts and utilities
scripts/local/
utils/local/

# Test artifacts
test-results/
test-reports/
.snapshots/

# Local development overrides
docker-compose.dev.yml
docker-compose.debug.yml
Dockerfile.dev
Dockerfile.debug