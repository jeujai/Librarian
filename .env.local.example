# =============================================================================
# MULTIMODAL LIBRARIAN - LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and customize the values for your local setup
# This file contains all environment variables needed for local development

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Environment type - determines which database clients to use
# Options: "local" (for development) or "aws" (for production)
ML_ENVIRONMENT=local
ML_DATABASE_TYPE=local
DATABASE_TYPE=local

# Application environment settings
DEBUG=true
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Application metadata
APP_NAME=Multimodal Librarian
APP_VERSION=1.0.0
ENVIRONMENT=development

# Configuration validation settings
VALIDATE_CONFIG_ON_STARTUP=true
STRICT_CONFIG_VALIDATION=false  # Set to true for production-like validation

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Configuration (Metadata and Configuration Storage)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=multimodal_librarian
POSTGRES_USER=ml_user
POSTGRES_PASSWORD=ml_password
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_POOL_SIZE=10
POSTGRES_POOL_OVERFLOW=20

# Neo4j Configuration (Knowledge Graph)
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ml_password
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# Milvus Configuration (Vector Database)
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=knowledge_chunks
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_METRIC_TYPE=L2
MILVUS_NLIST=1024

# Redis Configuration (Caching)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL=3600
CACHE_MAX_CONNECTIONS=10

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Security settings for local development
SECRET_KEY=local-dev-secret-key-change-in-production-this-should-be-32-chars-minimum
ENCRYPTION_KEY=bG9jYWwtZGV2LWVuY3J5cHRpb24ta2V5LWNoYW5nZS1pbi1wcm9kdWN0aW9u
REQUIRE_AUTH=false
ENABLE_REGISTRATION=true
SESSION_TIMEOUT=86400
PASSWORD_MIN_LENGTH=8

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20
WEBSOCKET_TIMEOUT=300

# CORS settings for local development
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://127.0.0.1:3000", "http://127.0.0.1:8000"]
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# EXTERNAL API CONFIGURATION
# =============================================================================
# AI/LLM Service API Keys (Required for AI functionality)
# Get these from the respective providers and add them here
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# Google/Gemini API (Optional - for additional AI capabilities)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# Anthropic Claude API (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-3-sonnet-20240229

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
# Local file storage paths (mounted as Docker volumes)
UPLOAD_DIR=/app/uploads
MEDIA_DIR=/app/media
EXPORT_DIR=/app/exports
BACKUP_DIR=/app/backups
LOG_DIR=/app/logs
AUDIT_LOG_DIR=/app/audit_logs

# File upload limits
MAX_FILE_SIZE=104857600  # 100MB in bytes
MAX_FILES_PER_UPLOAD=10
ALLOWED_FILE_TYPES=["pdf", "txt", "docx", "md"]

# Temporary file cleanup
TEMP_FILE_CLEANUP_INTERVAL=3600  # 1 hour
TEMP_FILE_MAX_AGE=86400  # 24 hours

# =============================================================================
# DOCUMENT PROCESSING CONFIGURATION
# =============================================================================
# PDF processing settings
PDF_EXTRACT_IMAGES=true
PDF_EXTRACT_TABLES=true
PDF_OCR_ENABLED=true
PDF_MAX_PAGES=1000

# Text chunking configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100
MAX_CHUNK_SIZE=2048

# Embedding model configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# =============================================================================
# KNOWLEDGE GRAPH CONFIGURATION
# =============================================================================
# Concept extraction settings
CONCEPT_EXTRACTION_ENABLED=true
MIN_CONCEPT_CONFIDENCE=0.7
MAX_CONCEPTS_PER_CHUNK=10

# Relationship extraction
RELATIONSHIP_EXTRACTION_ENABLED=true
MIN_RELATIONSHIP_CONFIDENCE=0.6
MAX_RELATIONSHIPS_PER_CONCEPT=20

# External knowledge bases
YAGO_ENDPOINT=https://yago-knowledge.org/sparql/query
CONCEPTNET_API_BASE=http://api.conceptnet.io
ENABLE_EXTERNAL_ENRICHMENT=true

# =============================================================================
# SEARCH AND RETRIEVAL CONFIGURATION
# =============================================================================
# Vector search settings
DEFAULT_SEARCH_K=10
MAX_SEARCH_K=100
SEARCH_SIMILARITY_THRESHOLD=0.7

# Hybrid search configuration
ENABLE_HYBRID_SEARCH=true
VECTOR_SEARCH_WEIGHT=0.7
KEYWORD_SEARCH_WEIGHT=0.3

# Search result ranking
ENABLE_RERANKING=true
RERANK_TOP_K=50

# =============================================================================
# CONVERSATION AND CHAT CONFIGURATION
# =============================================================================
# Chat settings
MAX_CONVERSATION_HISTORY=50
CONVERSATION_TIMEOUT=1800  # 30 minutes
ENABLE_CONVERSATION_MEMORY=true

# Response generation
MAX_RESPONSE_LENGTH=2048
RESPONSE_TEMPERATURE=0.7
ENABLE_STREAMING_RESPONSES=true

# Context window management
MAX_CONTEXT_TOKENS=4000
CONTEXT_OVERLAP_TOKENS=200

# =============================================================================
# MONITORING AND LOGGING CONFIGURATION
# =============================================================================
# Logging configuration
LOG_FORMAT=json
LOG_ROTATION_SIZE=100MB
LOG_RETENTION_DAYS=30
ENABLE_STRUCTURED_LOGGING=true

# Performance monitoring
ENABLE_METRICS_COLLECTION=true
METRICS_COLLECTION_INTERVAL=60  # seconds
ENABLE_PERFORMANCE_PROFILING=false

# Health check configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Error tracking
ENABLE_ERROR_TRACKING=true
ERROR_SAMPLING_RATE=1.0

# =============================================================================
# DEVELOPMENT AND DEBUGGING CONFIGURATION
# =============================================================================
# Development mode settings
ENABLE_HOT_RELOAD=true
ENABLE_DEBUG_TOOLBAR=true
ENABLE_API_DOCS=true
API_DOCS_URL=/docs

# Hot reload configuration (OPTIMIZED)
WATCHDOG_ENABLED=true
RELOAD_DIRS=/app/src/multimodal_librarian  # More specific for better performance
RELOAD_INCLUDES=*.py,*.yaml,*.yml,*.json,*.toml
RELOAD_EXCLUDES=__pycache__,*.pyc,*.pyo,*.pyd,.git,*.log,*.tmp
UVICORN_RELOAD=true
UVICORN_RELOAD_DELAY=0.5  # Faster reload delay
UVICORN_USE_COLORS=true
UVICORN_ACCESS_LOG=true
UVLOOP_ENABLED=1  # Enable uvloop for better performance

# Hot reload performance optimizations
HOT_RELOAD_DEBOUNCE_HIGH=0.5    # High priority files (config, main, routers)
HOT_RELOAD_DEBOUNCE_MEDIUM=1.0  # Medium priority files (services, components)
HOT_RELOAD_DEBOUNCE_LOW=2.0     # Low priority files (utils, monitoring)
HOT_RELOAD_DEBOUNCE_CONFIG=0.2  # Config file changes (fastest)
HOT_RELOAD_MAX_BATCH_SIZE=10    # Maximum changes to batch together
HOT_RELOAD_CACHE_SIZE=1000      # File hash cache size for change detection

# File watching settings (OPTIMIZED)
WATCH_POLL_INTERVAL=0.5  # Faster polling for better responsiveness
WATCH_RECURSIVE=true
DEBOUNCE_DELAY=0.5       # Reduced debounce delay

# Testing configuration
ENABLE_TEST_ENDPOINTS=true
TEST_DATA_SEED=true
MOCK_EXTERNAL_APIS=false

# Performance testing
ENABLE_LOAD_TESTING_ENDPOINTS=false
MAX_CONCURRENT_REQUESTS=100

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Feature toggles for development
ENABLE_DOCUMENT_UPLOAD=true
ENABLE_KNOWLEDGE_GRAPH=true
ENABLE_VECTOR_SEARCH=true
ENABLE_AI_CHAT=true
ENABLE_EXPORT_FUNCTIONALITY=true
ENABLE_ANALYTICS=true
ENABLE_USER_MANAGEMENT=false  # Disabled for local dev

# Experimental features
ENABLE_MULTIMODAL_PROCESSING=true
ENABLE_ADVANCED_CHUNKING=true
ENABLE_CROSS_DOCUMENT_LINKING=true

# =============================================================================
# RESOURCE LIMITS AND PERFORMANCE
# =============================================================================
# Application resource limits
MAX_WORKER_PROCESSES=4
MAX_WORKER_THREADS=10
WORKER_TIMEOUT=300

# Database connection limits
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Memory management
MAX_MEMORY_USAGE=2048  # MB
ENABLE_MEMORY_MONITORING=true
MEMORY_WARNING_THRESHOLD=1536  # MB

# =============================================================================
# BACKUP AND MAINTENANCE
# =============================================================================
# Backup configuration
ENABLE_AUTO_BACKUP=true
BACKUP_INTERVAL=86400  # 24 hours
BACKUP_RETENTION_DAYS=7
BACKUP_COMPRESSION=true

# Maintenance tasks
ENABLE_AUTO_CLEANUP=true
CLEANUP_INTERVAL=3600  # 1 hour
VACUUM_INTERVAL=86400  # 24 hours

# =============================================================================
# INTEGRATION TESTING
# =============================================================================
# Test database configuration (separate from main databases)
TEST_POSTGRES_DB=multimodal_librarian_test
TEST_NEO4J_DB=neo4j_test
TEST_MILVUS_COLLECTION=test_knowledge_chunks

# Test data configuration
GENERATE_TEST_DATA=true
TEST_DATA_SIZE=small  # small, medium, large
RESET_TEST_DATA_ON_STARTUP=true

# =============================================================================
# DOCKER COMPOSE PROFILES
# =============================================================================
# Control which services to start with Docker Compose profiles
# Uncomment the profiles you want to enable:

# COMPOSE_PROFILES=admin-tools          # Enable pgAdmin, Attu, Redis Commander
# COMPOSE_PROFILES=monitoring           # Enable log viewer and monitoring tools
# COMPOSE_PROFILES=admin-tools,monitoring  # Enable both admin tools and monitoring

# =============================================================================
# NOTES FOR DEVELOPERS
# =============================================================================
# 1. Copy this file to .env.local and customize the values
# 2. Never commit .env.local to version control
# 3. API keys are required for AI functionality - get them from:
#    - OpenAI: https://platform.openai.com/api-keys
#    - Google: https://console.cloud.google.com/apis/credentials
#    - Anthropic: https://console.anthropic.com/
# 4. For production deployment, use different configuration files
# 5. Resource limits can be adjusted based on your development machine
# 6. Enable/disable features using the feature flags section
# 7. Use Docker Compose profiles to control which services start