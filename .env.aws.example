# AWS Production Configuration for Multimodal Librarian
# Copy this file to .env.aws and customize as needed

# Environment
ENVIRONMENT=production
DATABASE_TYPE=aws

# AWS Configuration
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=

# Application Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=false
LOG_LEVEL=INFO

# Security Configuration
SECRET_KEY_SECRET_NAME=multimodal-librarian/aws-native/app-secrets
REQUIRE_AUTH=true
ENABLE_REGISTRATION=false
SESSION_TIMEOUT=86400
RATE_LIMIT_PER_MINUTE=1000

# RDS PostgreSQL Configuration
RDS_ENDPOINT=
RDS_PORT=5432
RDS_DATABASE=multimodal_librarian
RDS_SECRET_NAME=multimodal-librarian/aws-native/rds
RDS_SSL_MODE=require
RDS_POOL_SIZE=20
RDS_MAX_OVERFLOW=40

# Neptune Configuration
NEPTUNE_CLUSTER_ENDPOINT=
NEPTUNE_PORT=8182
NEPTUNE_SECRET_NAME=multimodal-librarian/aws-native/neptune
NEPTUNE_IAM_AUTH=true
NEPTUNE_SSL=true

# OpenSearch Configuration
OPENSEARCH_DOMAIN_ENDPOINT=
OPENSEARCH_PORT=443
OPENSEARCH_SECRET_NAME=multimodal-librarian/aws-native/opensearch
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_INDEX_PREFIX=ml

# S3 Configuration
S3_BUCKET=
S3_REGION=
S3_PREFIX=multimodal-librarian
S3_UPLOAD_PREFIX=uploads
S3_MEDIA_PREFIX=media
S3_EXPORT_PREFIX=exports
S3_BACKUP_PREFIX=backups
MAX_FILE_SIZE=10737418240  # 10GB - effectively unlimited
MAX_FILES_PER_UPLOAD=10

# Feature Flags
ENABLE_RELATIONAL_DB=true
ENABLE_VECTOR_SEARCH=true
ENABLE_GRAPH_DB=true
ENABLE_DOCUMENT_UPLOAD=true
ENABLE_KNOWLEDGE_GRAPH=true
ENABLE_AI_CHAT=true
ENABLE_EXPORT_FUNCTIONALITY=true
ENABLE_ANALYTICS=true
ENABLE_USER_MANAGEMENT=true

# Connection Settings
CONNECTION_TIMEOUT=60
QUERY_TIMEOUT=30
MAX_RETRIES=3

# Performance Settings
CONNECTION_POOLING=true
QUERY_CACHING=true
ENABLE_QUERY_LOGGING=false

# Embedding Configuration
EMBEDDING_DIMENSION=384
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# CloudWatch Configuration
CLOUDWATCH_LOG_GROUP=/aws/ecs/multimodal-librarian
CLOUDWATCH_LOG_STREAM_PREFIX=app
ENABLE_CLOUDWATCH_METRICS=true
ENABLE_XRAY_TRACING=true

# Auto Scaling Configuration
ENABLE_AUTO_SCALING=true
MIN_CAPACITY=1
MAX_CAPACITY=10
TARGET_CPU_UTILIZATION=70
TARGET_MEMORY_UTILIZATION=80

# Backup Configuration
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# Cost Optimization
ENABLE_COST_OPTIMIZATION=true
USE_SPOT_INSTANCES=false
ENABLE_RESOURCE_TAGGING=true
