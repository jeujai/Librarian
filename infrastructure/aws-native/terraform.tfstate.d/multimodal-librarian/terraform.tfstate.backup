            "query_definition_id": "11a2eab7-0227-4e2d-a910-29cb9fbcea33",
            "query_string": "fields @timestamp, @message\n| filter @message like /response_time/\n| parse @message /response_time: (?\u003cresponse_time\u003e\\d+)/\n| stats avg(response_time), max(response_time), min(response_time) by bin(5m)\n| sort @timestamp desc\n"
          },
          "sensitive_attributes": [],
          "private": "bnVsbA==",
          "dependencies": [
