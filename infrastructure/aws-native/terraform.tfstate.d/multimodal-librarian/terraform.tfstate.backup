    {
      "module": "module.monitoring",
      "mode": "managed",
      "type": "aws_cloudwatch_query_definition",
      "name": "model_loading_analysis",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "76992cec-2801-4f18-9540-0be075bf626f",
            "log_group_names": [
              "/aws/application/ml-librarian-prod"
            ],
            "name": "ml-librarian-prod-model-loading-analysis",
            "query_definition_id": "76992cec-2801-4f18-9540-0be075bf626f",
            "query_string": "fields @timestamp, model_name, duration_seconds, cache_hit, memory_usage_mb\n| filter component = \"ModelManager\"\n| filter message like /Model loaded/\n| stats avg(duration_seconds) as avg_load_time, count(*) as load_count, sum(cache_hit) as cache_hits by model_name\n| sort avg_load_time desc\n"
          },
          "sensitive_attributes": [],
          "private": "bnVsbA==",
          "dependencies": [
            "module.monitoring.aws_cloudwatch_log_group.application"
          ]
        }
      ]
