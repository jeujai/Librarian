        {
          "schema_version": 0,
          "attributes": {
            "dashboard_arn": "arn:aws:cloudwatch::591222106065:dashboard/ml-librarian-prod-startup-monitoring",
            "dashboard_body": "{\"widgets\":[{\"height\":6,\"properties\":{\"annotations\":{\"horizontal\":[{\"color\":\"#2ca02c\",\"fill\":\"below\",\"label\":\"Minimal Phase Target (30s)\",\"value\":30},{\"color\":\"#d62728\",\"fill\":\"above\",\"label\":\"Minimal Phase Threshold (60s)\",\"value\":60},{\"label\":\"Essential Phase Target (120s)\",\"value\":120},{\"label\":\"Essential Phase Threshold (180s)\",\"value\":180}]},\"metrics\":[[\"MultimodalLibrarian/prod/Startup\",\"MinimalPhaseCompletionTime\",{\"label\":\"Minimal Phase (avg)\",\"stat\":\"Average\"}],[\"...\",{\"label\":\"Minimal Phase (max)\",\"stat\":\"Maximum\"}],[\".\",\"EssentialPhaseCompletionTime\",{\"label\":\"Essential Phase (avg)\",\"stat\":\"Average\"}],[\"...\",{\"label\":\"Essential Phase (max)\",\"stat\":\"Maximum\"}],[\".\",\"FullPhaseCompletionTime\",{\"label\":\"Full Phase (avg)\",\"stat\":\"Average\"}],[\"...\",{\"label\":\"Full Phase (max)\",\"stat\":\"Maximum\"}]],\"period\":300,\"region\":\"us-east-1\",\"stacked\":false,\"title\":\"Startup Phase Completion Times\",\"view\":\"timeSeries\",\"yAxis\":{\"left\":{\"label\":\"Duration (seconds)\"}}},\"type\":\"metric\",\"width\":12,\"x\":0,\"y\":0},{\"height\":6,\"properties\":{\"metrics\":[[\"MultimodalLibrarian/prod/Startup\",\"ModelLoadingDuration\",{\"label\":\"Avg Load Time\",\"stat\":\"Average\"}],[\"...\",{\"label\":\"Max Load Time\",\"stat\":\"Maximum\"}],[\"...\",{\"label\":\"P95 Load Time\",\"stat\":\"p95\"}]],\"period\":300,\"region\":\"us-east-1\",\"stacked\":false,\"title\":\"Model Loading Performance\",\"view\":\"timeSeries\",\"yAxis\":{\"left\":{\"label\":\"Duration (seconds)\"}}},\"type\":\"metric\",\"width\":12,\"x\":12,\"y\":0},{\"height\":6,\"properties\":{\"metrics\":[[\"MultimodalLibrarian/prod/Startup\",\"ModelLoadingSuccessCount\",{\"label\":\"Successful Loads\",\"stat\":\"Sum\"}],[\".\",\"ModelLoadingFailureCount\",{\"label\":\"Failed Loads\",\"stat\":\"Sum\"}]],\"period\":300,\"region\":\"us-east-1\",\"stacked\":true,\"title\":\"Model Loading Success vs Failures\",\"view\":\"timeSeries\"},\"type\":\"metric\",\"width\":8,\"x\":0,\"y\":6},{\"height\":6,\"properties\":{\"annotations\":{\"horizontal\":[{\"color\":\"#2ca02c\",\"fill\":\"above\",\"label\":\"Target (70%)\",\"value\":70},{\"color\":\"#d62728\",\"fill\":\"below\",\"label\":\"Threshold (50%)\",\"value\":50}]},\"metrics\":[[{\"expression\":\"(hits / (hits + misses)) * 100\",\"id\":\"hit_rate\",\"label\":\"Cache Hit Rate %\"}],[\"MultimodalLibrarian/prod/Startup\",\"ModelCacheHitCount\",{\"id\":\"hits\",\"visible\":false}],[\".\",\"ModelCacheMissCount\",{\"id\":\"misses\",\"visible\":false}]],\"period\":300,\"region\":\"us-east-1\",\"stacked\":false,\"title\":\"Model Cache Hit Rate\",\"view\":\"timeSeries\",\"yAxis\":{\"left\":{\"label\":\"Hit Rate (%)\",\"max\":100,\"min\":0}}},\"type\":\"metric\",\"width\":8,\"x\":8,\"y\":6},{\"height\":6,\"properties\":{\"annotations\":{\"horizontal\":[{\"color\":\"#2ca02c\",\"fill\":\"below\",\"label\":\"Target (30s)\",\"value\":30000},{\"color\":\"#d62728\",\"fill\":\"above\",\"label\":\"P95 Threshold (60s)\",\"value\":60000}]},\"metrics\":[[\"MultimodalLibrarian/prod/Startup\",\"UserWaitTime\",{\"label\":\"Avg Wait Time\",\"stat\":\"Average\"}],[\"...\",{\"label\":\"P95 Wait Time\",\"stat\":\"p95\"}],[\"...\",{\"label\":\"Max Wait Time\",\"stat\":\"Maximum\"}]],\"period\":300,\"region\":\"us-east-1\",\"stacked\":false,\"title\":\"User Wait Times\",\"view\":\"timeSeries\",\"yAxis\":{\"left\":{\"label\":\"Wait Time (ms)\"}}},\"type\":\"metric\",\"width\":8,\"x\":16,\"y\":6},{\"height\":6,\"properties\":{\"metrics\":[[\"MultimodalLibrarian/prod/Startup\",\"FallbackResponseCount\",{\"label\":\"Fallback Responses\",\"stat\":\"Sum\"}],[\".\",\"HealthCheckFailureCount\",{\"label\":\"Health Check Failures\",\"stat\":\"Sum\"}]],\"period\":300,\"region\":\"us-east-1\",\"stacked\":false,\"title\":\"User Experience \u0026 Health Indicators\",\"view\":\"timeSeries\"},\"type\":\"metric\",\"width\":12,\"x\":0,\"y\":12},{\"height\":6,\"properties\":{\"query\":\"SOURCE '/aws/application/ml-librarian-prod' | fields @timestamp, phase, duration, status | filter component = 'StartupPhaseManager' | filter message like /Phase transition/ | sort @timestamp desc | limit 20\",\"region\":\"us-east-1\",\"title\":\"Recent Startup Phase Transitions\",\"view\":\"table\"},\"type\":\"log\",\"width\":12,\"x\":12,\"y\":12}]}",
