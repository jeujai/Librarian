      "module": "module.monitoring",
      "mode": "managed",
      "type": "aws_cloudwatch_query_definition",
      "name": "startup_phase_analysis",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "6949c744-21ee-4ae0-af02-c15de0e6dec9",
            "log_group_names": [
              "/aws/application/ml-librarian-prod"
            ],
            "name": "ml-librarian-prod-startup-phase-analysis",
            "query_definition_id": "6949c744-21ee-4ae0-af02-c15de0e6dec9",
            "query_string": "fields @timestamp, phase, duration, status\n| filter component = \"StartupPhaseManager\"\n| filter message like /Phase transition/\n| stats avg(duration) as avg_duration, max(duration) as max_duration, min(duration) as min_duration by phase\n| sort phase asc\n"
          },
          "sensitive_attributes": [],
          "private": "bnVsbA==",
          "dependencies": [
            "module.monitoring.aws_cloudwatch_log_group.application"
          ]
        }
      ]
    },
