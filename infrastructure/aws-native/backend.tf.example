# Terraform Backend Configuration for Production
# This file configures remote state storage in S3 with DynamoDB locking
# 
# To use this configuration:
# 1. Create the S3 bucket and DynamoDB table manually or using a separate Terraform configuration
# 2. Copy this file to backend.tf
# 3. Run `terraform init` to migrate state to remote backend

terraform {
  backend "s3" {
    # S3 bucket for storing Terraform state
    bucket = "multimodal-librarian-terraform-state-REPLACE-WITH-UNIQUE-SUFFIX"
    
    # State file path within the bucket
    key = "production/terraform.tfstate"
    
    # AWS region where the S3 bucket is located
    region = "us-east-1"
    
    # Enable server-side encryption for state file
    encrypt = true
    
    # DynamoDB table for state locking (prevents concurrent modifications)
    dynamodb_table = "multimodal-librarian-terraform-locks"
    
    # Additional security settings
    versioning = true
    
    # Workspace support for multiple environments
    workspace_key_prefix = "workspaces"
  }
}

# Example commands to create the required resources:
#
# 1. Create S3 bucket for state storage:
# aws s3 mb s3://multimodal-librarian-terraform-state-REPLACE-WITH-UNIQUE-SUFFIX --region us-east-1
# aws s3api put-bucket-versioning --bucket multimodal-librarian-terraform-state-REPLACE-WITH-UNIQUE-SUFFIX --versioning-configuration Status=Enabled
# aws s3api put-bucket-encryption --bucket multimodal-librarian-terraform-state-REPLACE-WITH-UNIQUE-SUFFIX --server-side-encryption-configuration '{"Rules":[{"ApplyServerSideEncryptionByDefault":{"SSEAlgorithm":"AES256"}}]}'
#
# 2. Create DynamoDB table for state locking:
# aws dynamodb create-table \
#   --table-name multimodal-librarian-terraform-locks \
#   --attribute-definitions AttributeName=LockID,AttributeType=S \
#   --key-schema AttributeName=LockID,KeyType=HASH \
#   --provisioned-throughput ReadCapacityUnits=5,WriteCapacityUnits=5 \
#   --region us-east-1
#
# 3. After creating resources, copy this file to backend.tf and run:
# terraform init -migrate-state